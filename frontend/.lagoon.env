# NEXT_PUBLIC_API_URL: Sets the API URL for the Nextjs frontend
# If NEXT_PUBLIC_API_URL is set, use that value
# Otherwise, use the first route from LAGOON_ROUTES (split by comma and take first value)
NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-${LAGOON_ROUTES%%,*}}

# NEXT_PUBLIC_NEW_DASHBOARD_URL: URL of the new dashboard (moad).
# When set, the root page shows a deprecation notice with a link to this URL.
# NEXT_PUBLIC_NEW_DASHBOARD_URL=https://dashboard.amazee.ai